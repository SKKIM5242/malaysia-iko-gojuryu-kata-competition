# Supabase — get from your project dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# App URL (used for absolute metadata/redirect URLs)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Online payment (optional) ────────────────────────────────────────────────
# When BOTH keys below are set and the competition has a fee, the register
# form requires successful Stripe Checkout payment BEFORE the registration is
# submitted. Leave blank to fall back to the manual bank-transfer flow.
# Server-side only — NEVER expose to the browser.
STRIPE_SECRET_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Optional but recommended: signing secret for the /api/stripe/webhook endpoint
STRIPE_WEBHOOK_SECRET=

# ── Telegram community groups (optional) ─────────────────────────────────────
# One dedicated group per registration category — shown as a "Join Telegram
# Group" button on that category's registration/payment confirmation screen.
# See docs/TELEGRAM_SETUP.md. Leave any blank to show the phone/email contact
# instead of a button for that category.
TELEGRAM_GROUP_PARTICIPANT=
TELEGRAM_GROUP_SCHOOL=
TELEGRAM_GROUP_REFEREE=
TELEGRAM_GROUP_AUDIENCE=
TELEGRAM_GROUP_STAFF=
