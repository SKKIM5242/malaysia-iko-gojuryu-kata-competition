# Supabase — get from your project dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# App URL (used for absolute metadata/redirect URLs)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Online payment (optional) ────────────────────────────────────────────────
# When BOTH keys below are set and the competition has a fee, the register
# form requires successful Stripe Checkout payment BEFORE the registration is
# submitted. Leave blank to fall back to the manual bank-transfer flow.
# Server-side only — NEVER expose to the browser.
STRIPE_SECRET_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Optional but recommended: signing secret for the /api/stripe/webhook endpoint
STRIPE_WEBHOOK_SECRET=

# ── Telegram community group (optional) ──────────────────────────────────────
# Shown as a "Join Telegram Group" button on payment-success pages once set.
# See docs/TELEGRAM_SETUP.md for how to create the group and find these values.
# Leave blank to show the phone/email contact instead of a button.
TELEGRAM_GROUP_URL=
# Numeric message-thread id of each Topic (optional — links straight to that
# topic instead of the group's General topic). Long-press a topic name in
# Telegram → Copy Link to see the number after the last slash.
TELEGRAM_TOPIC_PARTICIPANT=
TELEGRAM_TOPIC_SCHOOL=
TELEGRAM_TOPIC_SENSEI=
TELEGRAM_TOPIC_AUDIENCE=
